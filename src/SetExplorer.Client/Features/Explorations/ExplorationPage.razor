@page "/explorations/{Id:guid}"
@using SetExplorer.Client.Features.Collections
@using SetExplorer.Client.Core
@inject IExplorationsClient ExplorationsClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudExitPrompt Disabled="@(Id != Guid.Empty)" Title="Warning Guest Exploration" Text="Your exploration will be lost as soon as you leave this page"></MudExitPrompt>
<PageTitle>@(_exploration?.Name ?? "Exploration")</PageTitle>

@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudContainer>
}
else if (_exploration != null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <div class="d-flex align-center mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="BackToHome" />
            <MudText Typo="Typo.h4" Class="ml-2">@_exploration.Name</MudText>
        </div>
        <ExplorationEditor Exploration="_exploration" />
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudAlert Severity="Severity.Error">Exploration not found.</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="BackToHome" StartIcon="@Icons.Material.Filled.ArrowBack">Back to Home</MudButton>
    </MudContainer>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromQuery]
    public string? Name { get; set; }

    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    private ExplorationDto? _exploration;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadExploration();
    }

    private async Task LoadExploration()
    {
        _loading = true;
        try
        {
            if (Id == Guid.Empty)
            {
                _exploration = new ExplorationDto
                {
                    Id = ExplorationId.From(Guid.Empty),
                    Name = Name ?? "Guest Exploration",
                    SearchString = Search ?? string.Empty,
                    SeenCards = [],
                    UserId = UserId.From(Guid.Empty),
                    CardCollections = []
                };
            }
            else
            {
                _exploration = await ExplorationsClient.GetExplorationByIdAsync(ExplorationId.From(Id));
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load exploration.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BackToHome()
    {
        NavigationManager.NavigateTo("/");
    }
}
