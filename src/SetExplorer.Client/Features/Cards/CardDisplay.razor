@using SetExplorer.Client.Core.Scryfall.Models

<div class="card-display-container">
    <div class="card-image-wrapper">
        <CardImage Card="Card" IsSeen="IsSeen"></CardImage>
    </div>
    <div class="card-text-wrapper">
        @if (!Card.IsDoubleSided)
        {
            <MudCard Elevation="0" Style="background: transparent;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Card.Name</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body1">@Card.OracleText</MudText>
                </MudCardContent>
            </MudCard>
            
        }
        else
        {
            <div>
                <MudText Typo="Typo.h6">@Card.CardFaces[0].Name</MudText>
                <MudSpacer/>
                <MudText Typo="Typo.body1">@Card.CardFaces[0].OracleText</MudText>
            </div>
            <MudDivider DividerType="DividerType.FullWidth" Style="margin-top: 1rem; margin-bottom: 1rem"/>
            <div>
                <MudText Typo="Typo.h6">@Card.CardFaces[1].Name</MudText>
                <MudSpacer/>
                <MudText Typo="Typo.body1">@Card.CardFaces[1].OracleText</MudText>
            </div>
        }

    </div>
</div>

<style>
    .card-display-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        height: 100%;
        width: 100%;
        gap: 0.5rem;
    }

    .card-image-wrapper {
        flex: 0 0 auto;
        display: flex;
        justify-content: center;
    }

    .card-text-wrapper {
        flex: 1 1 auto;
        min-width: 0;
        width: 100%;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        overflow-y: auto;
        touch-action: pan-y;
    }

    @@media (min-width: 960px) {
        .card-display-container {
            flex-direction: row;
            align-items: center;
            justify-content: center;
            overflow-y: hidden;
            gap: 1.5rem;
        }
        
        .card-text-wrapper {
            height: 100%;
            overflow-y: auto;
            touch-action: auto;
        }
    }
</style>

@code {
    [Parameter, EditorRequired]
    public required ScryfallCard Card { get; set; }

    [Parameter]
    public bool IsSeen { get; set; }
}
