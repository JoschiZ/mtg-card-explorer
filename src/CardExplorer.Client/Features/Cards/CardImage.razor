@using CardExplorer.Client.Core.Scryfall.Models

<div class="basicCard_border basicCard_container">
    @if (!Card.IsDoubleSided)
    {
        <img
            class="basicCard_image"
            src="@_imageUrl"
            alt="@Card.Name"
            title="@Card.Name"/>
    }
    else
    {
        <MudFab Class="turn-button" IconSize="Size.Small" Size="Size.Small" Color="Color.Transparent" StartIcon="@Icons.Material.Filled.TurnRight" OnClick="@(() => _showFrontSide = !_showFrontSide)"></MudFab>
        if (_showFrontSide)
        {
            <img
                class="basicCard_image"
                src="@_frontSideImageUrl"
                alt="@Card.Name"
                title="@Card.Name"/>
        }
        else
        {
            <img
                class="basicCard_image"
                src="@_backSideImageUrl"
                alt="@Card.Name"
                title="@Card.Name"/>
        }
    } 
    @if (IsSeen)
    {
        <div class="seen-overlay">
            <MudIcon Icon="@Icons.Material.Filled.Visibility" Color="Color.Inherit" Size="Size.Large" />
            <MudText Typo="Typo.h6">Seen</MudText>
        </div>
    }
</div>

<!--suppress CssUnresolvedCustomProperty -->
<style>
    .basicCard_container{
        position: relative;
        aspect-ratio: 5/7;
        border-radius: 15px;
        overflow: hidden;
        max-height: 350px;
    }

    .basicCard_border {
        border: 1px solid #525252;
        background-color: #525252;
    }
    
    .basicCard_image{
        height: 100%;
        width: 100%;
        user-select: none;
    }
    
    .turn-button{
        position: absolute;
        top: 12%;
        left: 1%;
        border: 1px solid var(--mud-palette-lines-inputs);
        z-index: 2;
    }

    .seen-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(128, 128, 128, 0.4);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        pointer-events: none;
        z-index: 1;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public required ScryfallCard Card { get; set; }

    [Parameter]
    public bool IsSeen { get; set; }

    private bool _showFrontSide = true;

    private string? _imageUrl;
    private string? _frontSideImageUrl;
    private string? _backSideImageUrl;
    protected override void OnParametersSet()
    {
        _imageUrl = Card.GetCardImageUrl();
        if (Card.IsDoubleSided)
        {
            _frontSideImageUrl = Card.CardFaces[0].ImageUris.GetPreferredImageUrl();
            _backSideImageUrl = Card.CardFaces[1].ImageUris.GetPreferredImageUrl();
        }
    }

}