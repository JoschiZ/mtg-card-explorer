@using CardExplorer.Client.Core.Scryfall
@using CardExplorer.Client.Core.Scryfall.Models
@inject ScryfallSearchClient ScryfallClient

@if (_card is not null)
{
    <MudTooltip Style="padding: 0" Color="Color.Transparent" Placement="Placement.Right">
        <ChildContent>
            <MudText>@_card.Name</MudText>
        </ChildContent>
        <TooltipContent>
            <CardImage Card="_card"></CardImage>
        </TooltipContent>
    </MudTooltip>
}
else
{
    <MudSkeleton SkeletonType="SkeletonType.Text"></MudSkeleton>
}

@code {
    [Parameter, EditorRequired]
    public required ScryfallCardId CardId {get; set;}

    private ScryfallCard? _card;
    protected override async Task OnParametersSetAsync()
    {
        _card = await ScryfallClient.GetCardAsync(CardId);
    }

}