@using CardExplorer.Client.Core.Scryfall
@using CardExplorer.Client.Core.Scryfall.Models
@using CardExplorer.Client.Features.Collections
@using CardExplorer.Client.Features.Explorations
@inject ScryfallSearchClient SearchClient
@inject ILogger<Home> Logger
@inject ISnackbar Snackbar
@inject IExplorationsClient ExplorerClient
@inject AuthenticationStateProvider AuthenticationStateProvider

<div style="width: 100%; padding-bottom: 1rem">
    @if (_firstPage?.Warnings?.Length > 0)
    {
        foreach (var firstPageWarning in _firstPage.Warnings)
        {
            <MudAlert Severity="Severity.Error">@firstPageWarning</MudAlert>
        }
    }
    @if (_currentlyLoadingNewCards)
    {
        <MudProgressLinear Indeterminate Style="width: 100%;"/>
    }
    <MudCarousel TData="ScryfallCard" Style="height: 100%; width: 100%; " ShowArrows="true" ShowBullets="false" SelectedIndex="_selectedIndex" SelectedIndexChanged="@SelectedIndexChangedAsync" AutoCycle="false" EnableSwipeGesture="true">
        <ChildContent>
            @foreach (var card in _cards)
            {
                <MudCarouselItem Style="padding-left: 5%; padding-right: 5%; display: flex; align-items: center; justify-content: center;">
                    <CardDisplay Card="card" IsSeen="@SeenCards.Contains(card.Id)"/>
                </MudCarouselItem>
            }
        </ChildContent>
        <PreviousButtonTemplate>
            @if (_selectedIndex != 0)
            {
                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                    <div Class="mud-button-root mud-icon-button mud-icon-button-color-inherit mud-ripple mud-ripple-icon">
                        <span class="mud-icon-button-label">
                            <MudIcon Class="mud-ripple mud-ripple-icon mud-icon-button-size-medium" Icon="@Icons.Material.Filled.SkipPrevious" Color="@Color.Inherit"/>
                        </span>
                    </div>
                </div>
            }
        </PreviousButtonTemplate>
        <NextButtonTemplate>
            @if (_selectedIndex != _cards.Count - 1)
            {
                <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                    <div Class="mud-button-root mud-icon-button mud-icon-button-color-inherit mud-ripple mud-ripple-icon">
                        <span class="mud-icon-button-label">
                            <MudIcon Class="mud-ripple mud-ripple-icon mud-icon-button-size-medium" Icon="@Icons.Material.Filled.SkipNext" Color="@Color.Inherit"/>
                        </span>
                    </div>
                    @if (SelectedCard is not null && SeenCards.Contains(SelectedCard.Id))
                    {
                        <MudTooltip Text="Skip to next unseen card">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Inherit" OnClick="@SkipToNextUnseenAsync" Size="Size.Small"/>
                        </MudTooltip>
                    }
                </div>
            }
        </NextButtonTemplate>
    </MudCarousel>
    <div style="display: flex; justify-content: center; position: relative; margin-right: 0.2rem; margin-top: -1rem">
        <MudText Typo="Typo.h6">(@(ScryfallIndex) / @(_firstPage?.TotalCards ?? 0))</MudText>
    </div>
</div>

@code {
    
    
    private readonly List<ScryfallCard> _cards = [];
    private IAsyncEnumerator<ScryfallCard>? _currentSearchIterator;
    private int _selectedIndex;

    /// <summary>
    /// This is the index inside scryfall. It takes the starting page into account.
    /// </summary>
    private int ScryfallIndex => _selectedIndex + 1 + (_startingPage - 1 ?? 0) * ScryfallSearchPageSize;


    [Parameter] 
    public ICollection<ScryfallCardId> SeenCards { get; set; } = [];
    [Parameter]
    public ScryfallCard? SelectedCard { get; set; } 
    [Parameter]
    public EventCallback<ScryfallCard?> SelectedCardChanged { get; set; }
    [Parameter]
    public int? StartingPage { get; set; }
    private int? _startingPage;
    
    [Parameter, EditorRequired]
    public required ExplorationDto Exploration { get; set; }

    private string? _lastSearchString;
    
    [Parameter, EditorRequired]
    public required string SearchString { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(SearchString))
        {
            return;
        }

        if (SearchString == _lastSearchString)
        {
            return;
        }
        _lastSearchString = SearchString;
        _currentSearchIterator = SearchClient.GetAllAsync(SearchString, StartingPage).GetAsyncEnumerator();
        _startingPage = StartingPage;
        _cards.Clear();
        _selectedIndex = 0;
        // yes we fetch twice sorry scryfall
        var firstPageTask = SearchClient.SearchAsync(SearchString, null);
        await LoadNextCardsAsync();
        _firstPage = await firstPageTask;
        if (_cards.Count > 0)
        {
            SelectedCard = _cards[_selectedIndex];
            await SelectedCardChanged.InvokeAsync(SelectedCard);
        }
        
    }

    /// <summary>
    /// This is the page size of scryfalls search endpoint.
    /// Thus this is how much we can simply load without additional IO calls
    /// </summary>
    private const int ScryfallSearchPageSize = 175;
    private async Task<bool> LoadNextCardsAsync()
    {
        if (_currentSearchIterator is null)
        {
            return false;
        }

        if (_currentlyLoadingNewCards)
        {
            return true;
        }
        Logger.LogDebug("Loading next cards {amount} ...", ScryfallSearchPageSize);
        _currentlyLoadingNewCards = true;
        var itemsTaken = 0;
        while (itemsTaken < ScryfallSearchPageSize && await _currentSearchIterator.MoveNextAsync())
        {
            _cards.Add(_currentSearchIterator.Current);
            itemsTaken++;
        }
        _currentlyLoadingNewCards = false;
        return itemsTaken > 0;
    }

    private bool _currentlyLoadingNewCards;
    private ResultList<ScryfallCard>? _firstPage;

    private async Task SkipToNextUnseenAsync()
    {
        var nextUnseenCardIndex = -1;
        
        while (nextUnseenCardIndex == -1)
        {
            nextUnseenCardIndex = _cards.FindIndex(x => !SeenCards.Contains(x.Id));
            if (nextUnseenCardIndex == -1)
            {
                var newCardsLoaded = await LoadNextCardsAsync();
                if (!newCardsLoaded)
                {
                    Snackbar.Add("No unseen cards left", Severity.Info);
                    break;
                }
                continue;
            }
            await SelectedIndexChangedAsync(nextUnseenCardIndex);
        }
    }

    private async Task SelectedIndexChangedAsync(int newIndex)
    {
        if (newIndex < 0 || newIndex >= _cards.Count || newIndex == _selectedIndex)
        {
            return;
        }

        var newCard = _cards[newIndex];
        _selectedIndex = newIndex;
        SelectedCard = newCard;
        await SelectedCardChanged.InvokeAsync(SelectedCard);
        
        
        var cardPage = (int)Math.Floor(ScryfallIndex / (decimal)ScryfallSearchPageSize) + 1;
        if (cardPage != Exploration.CurrentPage && Exploration.Id != ExplorationId.From(Guid.Empty))
        {
            Exploration.CurrentPage = cardPage;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                var request = new PatchExplorationRequest
                {
                    Id = Exploration.Id,
                    CurrentPage = cardPage
                };
                await ExplorerClient.UpdateExplorationAsync(request);
            }
        }
        
        Logger.LogDebug("SelectedIndexChanged: {index}", newIndex);
        if (_cards.Count - newIndex <= 5)
        {
            await LoadNextCardsAsync();
        }
    }
}