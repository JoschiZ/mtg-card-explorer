@using CardExplorer.Client.Core
@inject ICollectionsClient CollectionsClient
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudDialog>
    <TitleContent>
        Select a Collection or Create one
    </TitleContent>
    <DialogContent>
        <MudForm Style="width: 100%">
            <MudTextField T="string" Label="Collection Name" @bind-Value="_request.Name" Required="true"/>
        </MudForm>
        <AuthorizeView>
            @if (_collections.Length > 0)
            {
                <MudDivider DividerType="DividerType.Middle"/>
                <MudText Typo="Typo.h5">Your Collections</MudText>
                <MudSelect T="CardCollectionDto" @bind-Value="_selectedExistingCollection">
                    @foreach (var collection in _collections.OrderBy(c => c.Name))
                    {
                        <MudSelectItem T="CardCollectionDto" Value="@collection">@collection.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Disabled="@(_selectedExistingCollection is null)" Color="Color.Primary" OnClick="@(() => MudDialog.Close(DialogResult.Ok(_selectedExistingCollection)))">Use Existing Collection</MudButton>
            } else {
                <MudAlert Severity="Severity.Info">There seem to be no collections</MudAlert>
            }
        </AuthorizeView>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    private readonly CreateCollectionRequest _request = new() { Name = "" };
    private CardCollectionDto[] _collections = [];
    private CardCollectionDto? _selectedExistingCollection;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            return;
        }
        _collections = await CollectionsClient.GetCollectionsAsync(new GetCollectionsRequest());
        await base.OnInitializedAsync();
    }

    private async Task Submit()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            var localCollection = new CardCollectionDto
            {
                Name = _request.Name,
                Id = CollectionId.From(Guid.Empty),
                Cards = [],
                UserId = UserId.From(Guid.Empty)
            };
            MudDialog.Close(DialogResult.Ok(localCollection));
            return;
        }

        var collection = await CollectionsClient.CreateCollectionAsync(_request);
        if (collection == null)
        {
            MudDialog.Cancel();
            return;
        }
        MudDialog.Close(DialogResult.Ok(collection));
    }

    private void Cancel() => MudDialog.Cancel();
}