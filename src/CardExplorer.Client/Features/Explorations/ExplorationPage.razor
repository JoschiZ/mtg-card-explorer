@page "/explorations/{Id:guid}"
@using CardExplorer.Client.Features.Collections
@using CardExplorer.Client.Core
@inject IExplorationsClient ExplorationsClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudExitPrompt Disabled="@(Id != Guid.Empty)" Title="Warning Guest Exploration" Text="Your exploration will be lost as soon as you leave this page"></MudExitPrompt>
<PageTitle>@(Exploration?.Name ?? "Exploration")</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning">
            This is the sandbox. Your progress will not be saved!
            Create an account to save your progress.
        </MudAlert>
    </NotAuthorized>
</AuthorizeView>
@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudContainer>
}
else if (Exploration != null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <div class="d-flex align-center mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="BackToHome" />
            <MudText Typo="Typo.h4" Class="ml-2">@Exploration.Name</MudText>
        </div>
        <ExplorationEditor Exploration="Exploration" />
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudAlert Severity="Severity.Error">Exploration not found.</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="BackToHome" StartIcon="@Icons.Material.Filled.ArrowBack">Back to Home</MudButton>
    </MudContainer>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromQuery]
    public string? Name { get; set; }

    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    [PersistentState]
    public ExplorationDto? Exploration {get; set;}

    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadExploration();
        await base.OnInitializedAsync();
    }

    private async Task LoadExploration()
    {
        if (Exploration != null) return;
        
        _loading = true;
        try
        {
            if (Id == Guid.Empty)
            {
                Exploration = new ExplorationDto
                {
                    Id = ExplorationId.From(Guid.Empty),
                    Name = Name ?? "Guest Exploration",
                    SearchString = Search ?? string.Empty,
                    SeenCards = [],
                    UserId = UserId.From(Guid.Empty),
                    CardCollections = []
                };
            }
            else
            {
                Exploration = await ExplorationsClient.GetExplorationByIdAsync(ExplorationId.From(Id));
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load exploration.", Severity.Error);
            NavigationManager.NavigateTo("/");
        }
        finally
        {
            _loading = false;
        }
    }

    private void BackToHome()
    {
        NavigationManager.NavigateTo("/");
    }
}
